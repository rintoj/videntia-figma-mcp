{
  "dxt_version": "0.1",
  "name": "videntia-figma-mcp",
  "display_name": "Figma MCP",
  "description": "AI-powered design tool for Figma - enables Claude and other AI tools to interact directly with Figma for AI-assisted design capabilities.",
  "version": "0.6.0",
  "author": {
    "name": "Videntia",
    "url": "https://github.com/videntia"
  },
  "license": "MIT",
  "homepage": "https://github.com/videntia/figma-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/videntia/figma-mcp.git"
  },
  "icon": "images/figma-mcp-icon.png",
  "compatibility": {
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  },
  "server": {
    "type": "node",
    "entry_point": "dist/videntia_figma_mcp/server.cjs",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/dist/videntia_figma_mcp/server.cjs",
        "--server=${user_config.server_url}"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "user_config": {
    "server_url": {
      "type": "string",
      "title": "Socket Server URL",
      "description": "WebSocket socket server host. Use 'localhost' for local dev or 'figma-mcp.videntia.dev' for the hosted server.",
      "default": "figma-mcp.videntia.dev",
      "required": false
    }
  },
  "tools_generated": true
}
